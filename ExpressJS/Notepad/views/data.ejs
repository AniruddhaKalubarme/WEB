<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notepad</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-100 min-h-screen p-10">
    <div class="max-w-4xl mx-auto">
        <a href="/" class="inline-block mb-6 text-blue-600 hover:text-blue-800 transition-colors font-medium text-lg">
            Back to Home
        </a>

        <div class="bg-white p-8 rounded-xl shadow-lg border border-zinc-200">
            <h1 class="text-3xl font-bold text-zinc-900 mb-2 capitalize">
                <%= filename.replace('.txt', '' ) %>
            </h1>
            <p class="text-zinc-400 text-sm mb-6 uppercase tracking-wider font-semibold">Note Details</p>

            <div
                class="text-zinc-700 text-lg leading-relaxed whitespace-pre-wrap bg-zinc-50 p-6 rounded-lg border border-zinc-100">
                <%= data %>
            </div>
        </div>
    </div>

    <script src="/javascripts/script.js"></script>
</body>

</html>