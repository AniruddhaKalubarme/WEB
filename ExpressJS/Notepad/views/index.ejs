<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notepad</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

    <div class="flex bg-zinc-100 w-full">
        <div class="min-h-screen flex flex-1 items-center pl-10">
            <form class="bg-white p-8 rounded-xl shadow-lg" action="/create" method="post">
                <h1 class="text-2xl font-bold mb-6 text-zinc-800">Create Note</h1>

                <input
                    class="block w-full border border-zinc-300 rounded-md px-4 py-2 mb-4 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    type="text" placeholder="Title" name="title">

                <textarea
                    class="block w-72 border border-zinc-300 rounded-md p-4 mb-4 h-40 resize-none focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    placeholder="Write your note details here..." name="details"></textarea>

                <button
                    class="w-full bg-blue-600 text-white font-medium py-2 px-4 rounded-md hover:bg-blue-700 transition-colors duration-200">Submit Note </button>
            </form>

        </div>
        <div class="flex-1 pt-10">
            <div class="text-2xl font-bold mb-6 text-zinc-800 flex gap-10"> Notes </div>
            <% if(files.length> 0) { %>
                <% files.forEach(function(val){ %>
                    <div class="text-xl bg-white mt-2 w-fit px-2 py-1 rounded-lg flex flex-col"> file is present:
                        <a href="/file/<%= val %>" class="text-blue-500 cursor-pointer"><%= val %></a>
                        <a href="/rename/<%= val %>" class="text-blue-500 cursor-pointer"> Rename </a>
                        <a href="/delete/<%= val %>" class="text-red-500 cursor-pointer"> Delete </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-zinc-500 m-2">No notes yet.</div>
            <% } %>

        </div>

    </div>


    <script src="/javascripts/script.js"></script>
</body>

</html>