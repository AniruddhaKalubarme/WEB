<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Employee List</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen relative overflow-x-hidden text-zinc-800">

    <!-- Background Decoration -->
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 bg-zinc-50 pointer-events-none">
        <div class="absolute top-[-10%] left-[-5%] w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-96 h-96 bg-purple-100 rounded-full blur-3xl opacity-50"></div>
    </div>

    <!-- Navigation / Header -->
    <header
        class="w-full p-6 lg:px-12 flex flex-col md:flex-row justify-between items-center gap-4 z-10 sticky top-0 bg-gray-50/80 backdrop-blur-md border-b border-zinc-200/50">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-zinc-900">Employee Directory</h1>
            <p class="text-sm text-zinc-500">Manage your team members and their details.</p>
        </div>

        <a href="/"
            class="group flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-full font-medium text-sm shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:shadow-blue-600/40 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                class="w-5 h-5 group-hover:rotate-90 transition-transform">
                <path
                    d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
            </svg>
            <span>Add New Employee</span>
        </a>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-6 py-8">
        <% if (users.length===0) { %>
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="bg-zinc-100 p-6 rounded-full mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="w-10 h-10 text-zinc-400">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 5.472m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold text-zinc-800">No employees found</h3>
                <p class="text-zinc-500 mt-2 max-w-xs">It looks like the directory is empty. Start by adding a new
                    employee.</p>
            </div>
            <% } else { %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    <% users.forEach(function(user){ %>
                        <div
                            class="group bg-white rounded-2xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-zinc-100 flex flex-col items-center text-center relative overflow-hidden">

                            <!-- Decoration Gradient -->
                            <div
                                class="absolute top-0 left-0 w-full h-20 bg-gradient-to-b from-blue-50 to-transparent -z-0">
                            </div>

                            <!-- Image -->
                            <div
                                class="relative z-10 w-24 h-24 mb-4 rounded-full p-1 bg-white border border-zinc-100 shadow-sm">
                                <img src="<%= user.Image %>" alt="<%= user.Name %>"
                                    class="w-full h-full object-cover rounded-full">
                            </div>

                            <!-- Info -->
                            <div class="relative z-10 w-full mb-6">
                                <h2 class="text-lg font-bold text-zinc-900 truncate px-2" title="<%= user.Name %>">
                                    <%= user.Name %>
                                </h2>
                                <p class="text-sm text-zinc-500 truncate px-2" title="<%= user.Email %>">
                                    <%= user.Email %>
                                </p>

                                <div
                                    class="mt-3 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-zinc-100 text-xs font-medium text-zinc-600">
                                    <span>Age:</span>
                                    <span class="font-bold text-zinc-800">
                                        <%= user.Age %>
                                    </span>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div
                                class="relative z-10 w-full grid grid-cols-2 gap-3 mt-auto border-t border-zinc-100 pt-4">
                                <a href="/Edit/<%= user._id %>"
                                    class="flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                    </svg>
                                    Edit
                                </a>
                                <a href="/Delete/<%= user._id %>"
                                    class="flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                    </svg>
                                    Delete
                                </a>
                            </div>

                        </div>
                        <% }) %>
                </div>
                <% } %>
    </main>

</body>

</html>