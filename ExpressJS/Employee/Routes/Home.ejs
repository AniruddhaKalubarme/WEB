<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Employee Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen relative overflow-hidden text-zinc-800">

    <!-- Background Decoration -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10 bg-zinc-50">
        <div class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-50"></div>
    </div>

    <!-- Navigation / Header -->
    <nav class="absolute top-0 left-0 w-full p-6 flex justify-between items-center z-10">
        <div class="text-xl font-bold tracking-tight text-zinc-900">EmpManager</div>
        <a href="/submit"
            class="group flex items-center gap-2 bg-white border border-zinc-200 text-zinc-600 px-5 py-2.5 rounded-full font-medium text-sm shadow-sm hover:shadow-md hover:border-blue-400 hover:text-blue-600 transition-all duration-300">
            <span>View Employees</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
        </a>
    </nav>

    <!-- Main Content -->
    <div class="flex items-center justify-center min-h-screen px-4 py-12">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl shadow-xl border border-zinc-100 overflow-hidden relative">

                <!-- Card Header -->
                <div class="bg-blue-600 p-8 text-center relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-blue-500 to-indigo-600">
                    </div>
                    <h1 class="text-2xl font-bold text-white relative z-10">Add New Employee</h1>
                    <p class="text-blue-100 text-sm mt-2 relative z-10">Enter the details to create a new profile</p>
                </div>

                <!-- Form -->
                <form method="Post" action="/submit" class="p-8 space-y-5">

                    <div class="space-y-1">
                        <label for="Name" class="block text-sm font-medium text-zinc-700 ml-1">Full Name</label>
                        <input required id="Name" name="Name" type="text" placeholder="e.g. John Doe"
                            class="w-full px-4 py-3 rounded-lg bg-zinc-50 border border-zinc-200 text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-300">
                    </div>

                    <div class="space-y-1">
                        <label for="Email" class="block text-sm font-medium text-zinc-700 ml-1">Email Address</label>
                        <input required id="Email" name="Email" type="email" placeholder="e.g. john@example.com"
                            class="w-full px-4 py-3 rounded-lg bg-zinc-50 border border-zinc-200 text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-300">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-1">
                            <label for="Age" class="block text-sm font-medium text-zinc-700 ml-1">Age</label>
                            <input required id="Age" name="Age" type="number" placeholder="25"
                                class="w-full px-4 py-3 rounded-lg bg-zinc-50 border border-zinc-200 text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-300">
                        </div>
                        <div class="space-y-1">
                            <label for="Profile" class="block text-sm font-medium text-zinc-700 ml-1">Profile Image
                                URL</label>
                            <input required id="Profile" name="Profile" type="text" placeholder="https://..."
                                class="w-full px-4 py-3 rounded-lg bg-zinc-50 border border-zinc-200 text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-300">
                        </div>
                    </div>

                    <div class="pt-2">
                        <button type="submit"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3.5 rounded-xl shadow-lg shadow-blue-500/30 hover:shadow-blue-600/40 active:scale-[0.98] transition-all duration-300 flex justify-center items-center gap-2 group">
                            <span>Create Employee</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                class="w-5 h-5 group-hover:translate-x-0.5 transition-transform">
                                <path fill-rule="evenodd"
                                    d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-11.25a.75.75 0 0 0-1.5 0v2.5h-2.5a.75.75 0 0 0 0 1.5h2.5v2.5a.75.75 0 0 0 1.5 0v-2.5h2.5a.75.75 0 0 0 0-1.5h-2.5v-2.5Z"
                                    clip-rule="evenodd" />
                            </svg>
                        </button>
                    </div>

                </form>
            </div>

            <p class="text-center text-zinc-400 text-sm mt-8">
                &copy; 2026 Employee Management System
            </p>
        </div>
    </div>
</body>

</html>